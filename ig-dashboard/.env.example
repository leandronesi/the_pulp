# Turso — copia in .env e metti i tuoi valori.
# Se non set → fallback a SQLite locale in data/pulp.db.
#
# Da app.turso.tech → il tuo DB → Connect:
#   - Database URL (libsql://...)
#   - Auth Token (Create Token, scadenza Never)

TURSO_DATABASE_URL=
TURSO_AUTH_TOKEN=

# OpenAI — usato da scripts/briefing.js per generare le sezioni narrative.
# Se vuoto, il briefing esce con placeholder [LLM needed] e funziona comunque.
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5.4-mini
